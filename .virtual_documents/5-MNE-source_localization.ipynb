from mne.minimum_norm import make_inverse_operator, apply_inverse

# ── Select evoked conditions ──────────────────────────────────────────────────.

evoked_dict = {ev.comment: ev for ev in evokeds}
print('Available evoked conditions:')
for k in evoked_dict.keys():
    print(f'  {k!r}')

STANDARD_KEY = 'standard_onset'  # <-- edit me
MMN_KEY      = 'MMN context-matched (deviant - preceding standard)'  # <-- edit me

evoked_standard = evoked_dict[STANDARD_KEY]
evoked_mmn      = evoked_dict[MMN_KEY]

print(f'\nSelected:')
print(f'  Standard (M100) : {STANDARD_KEY!r}  (n={evoked_standard.nave})')
print(f'  MMN             : {MMN_KEY!r}  (n={evoked_mmn.nave})')

# ── Regularization ────────────────────────────────────────────────────────────
# SNR=3 is the standard assumption for averaged evoked data.
# lambda2 controls the trade-off between data fit and solution smoothness.
snr     = 3.0
lambda2 = 1.0 / snr ** 2
print(f'\nSNR assumption : {snr}')
print(f'lambda2        : {lambda2:.4f}')

# ── Build the inverse operator ────────────────────────────────────────────────
# Combines the forward solution + noise covariance into a set of weights
# that map sensor data back to source space.
#
# loose=0.2  -- small deviations from surface-normal orientation allowed
# depth=0.8  -- depth weighting to partially correct superficial bias
inverse_operator = make_inverse_operator(
    evoked_standard.info,
    fwd,
    noise_cov,
    loose=0.2,
    depth=0.8,
    verbose=False
)
print('\nInverse operator:')
print(inverse_operator)

inv_path = DERIV_DIR / f'{sub_label}_{ses_label}_task-{TASK}_inv.fif'
mne.minimum_norm.write_inverse_operator(inv_path, inverse_operator, overwrite=True)
print(f'Saved: {inv_path}')

# ── Apply MNE ─────────────────────────────────────────────────────────────────
# Two conditions only:
#   standard tones -> M100 (auditory cortex, 100-120 ms)
#   MMN contrast   -> mismatch negativity source (175-225 ms)
#
# Output units: nAm (nano-Ampere-meters) -- physical current dipole moment.
stc_mne_standard = apply_inverse(
    evoked_standard, inverse_operator, lambda2=lambda2, method='MNE', verbose=False
)
stc_mne_mmn = apply_inverse(
    evoked_mmn, inverse_operator, lambda2=lambda2, method='MNE', verbose=False
)

print('\nMNE source estimates:')
print(f'  Standard (M100) : {stc_mne_standard.data.shape}  (sources x timepoints)')
print(f'  MMN             : {stc_mne_mmn.data.shape}')
print(f'  Output units    : nAm')
print(f'  MMN range       : {stc_mne_mmn.data.min():.3e} to {stc_mne_mmn.data.max():.3e} nAm')

for stc, name in [
    (stc_mne_standard, 'mne-standard'),
    (stc_mne_mmn,      'mne-mmn'),
]:
    stc_path = DERIV_DIR / f'{sub_label}_{ses_label}_task-{TASK}_{name}'
    stc.save(stc_path, overwrite=True)
    print(f'  Saved: {stc_path}-lh.stc')






# ── Brain surface plots: MNE ─────────────────────────────────────────────────

brain_mne_m100 = stc_mne_standard.plot(
    subject=fs_subject,
    subjects_dir=SUBJECTS_DIR,
    hemi='both',
    surface='inflated',
    time_viewer=True,
    show_traces=True,
    colormap='hot',
    clim=dict(kind='percent', lims=[90, 95, 99]),
    title='MNE Standard -- M100 (nAm)',
    initial_time=.110,
)


brain_mne_mmn = stc_mne_mmn.plot(
    subject=fs_subject,
    subjects_dir=SUBJECTS_DIR,
    hemi='both',
    surface='inflated',
    time_viewer=True,
    show_traces=True,
